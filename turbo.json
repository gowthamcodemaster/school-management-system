{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": ["**/.env.*local"],
    "pipeline": {
        "build": {
        "dependsOn": ["^build"],
        "outputs": [".next/**","!.next/cache/**","dist/**", "lib/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
        "dependsOn": ["^lint"]
        },
        "test": {
        "dependsOn": ["^build"],
        "outputs": ["coverage/**", "test-results/**"]
        },
        "clean": {
        "cache": false
        }
    }
}