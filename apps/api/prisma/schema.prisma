// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER MODEL
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      UserRole @default(TEACHER)
  
  firstName String
  lastName  String
  phone     String?
  
  isActive  Boolean  @default(true)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  teacher   Teacher?

  // ── Auth fields ──────────────────────────
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime?

  // ── MFA fields ───────────────────────────
  mfaEnabled Boolean    @default(false)
  mfaSecret  String?    // TOTP secret — encrypted at application level
  mfaMethod  MfaMethod?

  refreshTokens RefreshToken[]

  @@index([email])  
  @@map("users")
}

// ============================================
// REFRESH TOKEN MODEL
// ============================================

model RefreshToken {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime
  isRevoked Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}


enum UserRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
}

enum MfaMethod {
  TOTP
  EMAIL_OTP
}


// ============================================
// STUDENT MODEL
// ============================================

model Student {
  id          String   @id @default(cuid())
  studentId   String   @unique
  
  firstName   String
  lastName    String
  email       String   @unique
  dateOfBirth DateTime @db.Date
  gender      Gender
  bloodGroup  String?
  
  phone       String?
  address     String?
  city        String?
  state       String?
  pincode     String?
  
  classId     String
  class       Class    @relation(fields: [classId], references: [id])
  section     String
  rollNumber  Int
  
  admissionDate DateTime @db.Date @default(now())
  status        StudentStatus @default(ACTIVE)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  attendance  Attendance[]
  
  @@unique([classId, rollNumber])
  @@index([studentId])
  @@index([classId, section])
  @@map("students")
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  TRANSFERRED
  EXPELLED
}

// ============================================
// TEACHER MODEL
// ============================================

model Teacher {
  id          String   @id @default(cuid())
  staffId     String   @unique
  
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  
  subject     String?
  department  String?
  designation String?
  
  joiningDate DateTime @db.Date
  
  phone       String?
  address     String?
  
  status      TeacherStatus @default(ACTIVE)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  attendance  Attendance[]
  
  @@index([staffId])
  @@map("teachers")
}

enum TeacherStatus {
  ACTIVE
  ON_LEAVE
  INACTIVE
  RESIGNED
}

// ============================================
// CLASS MODEL
// ============================================

model Class {
  id          String   @id @default(cuid())
  name        String
  academicYear String
  
  maxStudents Int      @default(40)
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  students    Student[]
  
  @@unique([name, academicYear])
  @@map("classes")
}

// ============================================
// ATTENDANCE MODEL
// ============================================

model Attendance {
  id              String   @id @default(cuid())
  
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id])
  
  attendanceDate  DateTime @db.Date
  status          AttendanceStatus
  
  markedBy        String?
  teacher         Teacher? @relation(fields: [markedBy], references: [id])
  
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([studentId, attendanceDate])
  @@index([attendanceDate])
  @@index([studentId])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  LEAVE
}

